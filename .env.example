# Supabase (Auth + DB)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=
# Optional alias (same value as KEY)
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# API HTTP (Axios). Optional — defaults to Supabase URL if empty.
EXPO_PUBLIC_API_URL=

# EAS project id (Expo push). Fill after `eas init`.
EXPO_PUBLIC_EAS_PROJECT_ID=

# Stripe (public key only — secrets stay on backend)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# RevenueCat (public SDK key)
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=

# --- Server-only (Edge Functions / worker — never ship in the app) ---
